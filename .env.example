# Aether API - Environment Configuration
# Copy to .env and fill in required values

# =============================================================================
# REQUIRED - OpenRouter (LLM Gateway)
# =============================================================================
OPENROUTER_API_KEY=                    # Get from https://openrouter.ai/keys
# OPENROUTER_HTTP_REFERER=             # Optional: Your app URL for OpenRouter analytics
# OPENROUTER_APP_TITLE=Aether          # Optional: App name shown in OpenRouter

# =============================================================================
# REQUIRED - Qdrant (Vector Database)
# =============================================================================
QDRANT_API_KEY=                        # Qdrant Cloud API key (or leave empty for local)
# QDRANT_URL=http://localhost:6333     # Optional: Override Qdrant endpoint (default: localhost:6333)

# =============================================================================
# REQUIRED - Firebase (User Data & Auth)
# =============================================================================
# FIREBASE_SERVICE_ACCOUNT_PATH=serviceAccountKey.json  # Local file path (dev)
FIREBASE_SERVICE_ACCOUNT_JSON=         # Full JSON credentials (prod - paste entire JSON here, takes priority over path)

# =============================================================================
# OPTIONAL - OpenRouter Tuning
# =============================================================================
# OPENROUTER_TIMEOUT_SECONDS=45        # Request timeout (default: 45)
# OPENROUTER_MAX_RETRIES=2             # Retry attempts for 429/503 (default: 2)

# =============================================================================
# OPTIONAL - API Settings
# =============================================================================
# ALLOWED_ORIGINS=*                    # CORS origins (comma-separated, default: *)
# DEBUG=false                          # Enable debug mode + /docs Swagger (default: false)

# =============================================================================
# NOTES
# =============================================================================
# - Never commit .env or serviceAccountKey.json (both in .gitignore)
# - FIREBASE_SERVICE_ACCOUNT_JSON takes priority over FIREBASE_SERVICE_ACCOUNT_PATH
# - For local dev with Docker: use docker-compose.local.yml (exposes Qdrant on :6333)
# - For production: use docker-compose.yml (Dokploy network)
# - OpenRouter models: deepseek/deepseek-v4-pro (chat) + nvidia/nemotron-3-ultra-550b-a55b:free (background)